{
  "extends": "../../tsconfig-base.json",
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "outDir": "./tools",
    "moduleResolution": "bundler",
    "rootDir": "src",
    "skipLibCheck": true,
    "isolatedModules": false,
    "noEmit": false,
    "resolveJsonModule": true
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx"]
}
